# API (copy to api/.env)
DATABASE_URL="postgresql://ap:ap@localhost:5432/company_ap?schema=public"
JWT_SECRET="replace-with-long-random-string"
PORT=4001
UPLOAD_DIR="./uploads"
FRONTEND_URL="http://localhost:5173"
# Optional image OCR for invoice slips. If absent, image uploads stay manual.
# Groq is the primary vision OCR provider. Gemini and OpenAI are fallbacks.
GROQ_API_KEY=""
GROQ_OCR_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"
GROQ_API_BASE_URL="https://api.groq.com/openai/v1"
GEMINI_API_KEY=""
GEMINI_OCR_MODEL="gemini-2.5-flash"
GEMINI_API_BASE_URL="https://generativelanguage.googleapis.com/v1beta"
OPENAI_API_KEY=""
OPENAI_OCR_MODEL="gpt-4.1-mini"
OPENAI_OCR_FALLBACK_MODEL="gpt-4o-mini"
# Optional alternative OCR service accepting JSON { fileName, mimeType, base64 }.
OCR_API_URL=""
OCR_API_KEY=""
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
XERO_CLIENT_ID="..."
XERO_CLIENT_SECRET="..."
XERO_TENANT_ID="..."
XERO_REDIRECT_URI="http://localhost:4000/api/xero/callback"
XERO_SCOPES="openid profile email accounting.transactions offline_access"
XERO_DEFAULT_EXPENSE_ACCOUNT="500"
XERO_BANK_ACCOUNT_CODE="090"
MEEZAN_PAYMENT_EXPORT_FORMAT="CSV"

# Web (copy to web/.env.local)
VITE_API_URL="http://localhost:4001"
