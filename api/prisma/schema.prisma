generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  COMPANY_ADMIN
  AP_CLERK
  DEPT_ADMIN
}

enum VendorKind {
  RECURRING
  ONE_OFF
}

enum InvoiceStatus {
  UPLOADED
  EXTRACTED
  VENDOR_UNVERIFIED
  VENDOR_VERIFIED
  AWAITING_APPROVAL
  APPROVED
  REJECTED
  PAYMENT_INITIATED
  PAID
}

enum TaxFilerStatus {
  FILER
  NON_FILER
}

model Department {
  id       String    @id @default(uuid())
  name     String
  users    User[]
  invoices Invoice[]
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  passwordHash   String
  name           String
  role           Role
  departmentId String?
  department     Department?  @relation(fields: [departmentId], references: [id])
  submittedInvoices Invoice[] @relation("SubmittedInvoices")
  approvals      Approval[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Vendor {
  id          String     @id @default(uuid())
  displayName String
  legalName   String?
  taxNumber   String?    @unique
  kind        VendorKind @default(RECURRING)
  active      Boolean    @default(true)
  invoices    Invoice[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Invoice {
  id                 String        @id @default(uuid())
  reference          String?
  amountPkr          Decimal       @db.Decimal(14, 2)
  taxFilerStatus     TaxFilerStatus @default(FILER)
  whtTax             Decimal       @default(0) @db.Decimal(7, 2)
  salesTax           Decimal       @default(0) @db.Decimal(7, 2)
  incomeTax          Decimal       @default(0) @db.Decimal(7, 2)
  totalAmountPkr     Decimal       @default(0) @db.Decimal(14, 2)
  dueDate            DateTime?
  description        String?
  status             InvoiceStatus @default(UPLOADED)
  fileRelPath        String?
  originalFilename   String?
  mimeType           String?
  extracted          Json?
  vendorId           String?
  vendor             Vendor?       @relation(fields: [vendorId], references: [id])
  departmentId       String
  department         Department    @relation(fields: [departmentId], references: [id])
  submittedById    String
  submittedBy        User          @relation("SubmittedInvoices", fields: [submittedById], references: [id])
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  approvals          Approval[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model Approval {
  id         String   @id @default(uuid())
  invoiceId  String
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  approverId String
  approver   User     @relation(fields: [approverId], references: [id])
  approved   Boolean
  note       String?
  createdAt  DateTime @default(now())
}
