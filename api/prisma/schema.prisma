generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Department {
  id       String    @id @default(uuid())
  name     String
  users    User[]
  invoices Invoice[]
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  passwordHash   String
  name           String
  role           String
  departmentId String?
  department     Department?  @relation(fields: [departmentId], references: [id])
  submittedInvoices Invoice[] @relation("SubmittedInvoices")
  approvals      Approval[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Vendor {
  id          String     @id @default(uuid())
  displayName String
  legalName   String?
  taxNumber   String?    @unique
  kind        String     @default("RECURRING")
  active      Boolean    @default(true)
  invoices    Invoice[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Invoice {
  id                 String        @id @default(uuid())
  reference          String?
  amountPkr          Decimal
  dueDate            DateTime?
  description        String?
  status             String        @default("UPLOADED")
  fileRelPath        String?
  originalFilename   String?
  mimeType           String?
  extracted          String?
  vendorId           String?
  vendor             Vendor?       @relation(fields: [vendorId], references: [id])
  departmentId       String
  department         Department    @relation(fields: [departmentId], references: [id])
  submittedById    String
  submittedBy        User          @relation("SubmittedInvoices", fields: [submittedById], references: [id])
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  approvals          Approval[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model Approval {
  id         String   @id @default(uuid())
  invoiceId  String
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  approverId String
  approver   User     @relation(fields: [approverId], references: [id])
  approved   Boolean
  note       String?
  createdAt  DateTime @default(now())
}
